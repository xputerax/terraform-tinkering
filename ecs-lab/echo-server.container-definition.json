[
  {
    "name": "echo-server",
    "image": "ealen/echo-server",
    "cpu": 512,
    "memory": 128,
    "portMappings": [
      {
        "containerPort": 80,
        "hostPort": 80,
        "protocol": "tcp"
      }
    ],
    "restartPolicy": {
      "enabled": true,
      "ignoredExitCodes": [0],
      "restartAttemptPeriod": 180
    },
    "logConfiguration": {
      "logDriver": "awslogs",
      "options": {
        "awslogs-region": "ap-southeast-5",
        "awslogs-group": "/ecs/echo-server"
      }
    }
  }
]
