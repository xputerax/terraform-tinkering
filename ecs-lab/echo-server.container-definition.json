[
  {
    "name": "echo-server",
    "image": "ealen/echo-server",
    "cpu": 512,
    "memory": 128,
    "portMappings": [
      {
        "name": "web",
        "containerPort": 80,
        "hostPort": 80,
        "protocol": "tcp"
      }
    ],
    "restartPolicy": {
      "enabled": true,
      "ignoredExitCodes": [0],
      "restartAttemptPeriod": 180
    },
    "logConfiguration": {
      "logDriver": "awslogs",
      "options": {
        "awslogs-region": "ap-southeast-5",
        "awslogs-group": "/ecs/echo-server"
      }
    },
    "healthCheck": {
      "command": ["CMD-SHELL", "wget -q -O /dev/null http://127.0.0.1:80/ || exit 1"],
      "interval": 30,
      "timeout": 5,
      "retries": 3,
      "startPeriod": 10
    }
  }
]
