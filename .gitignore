# Terraform
.terraform/

# State files (may contain secrets; manage via remote backend, not git)
*.tfstate
*.tfstate.*

# Variable files (often hold secrets)
*.tfvars
*.tfvars.json

# Crash logs
crash.log
crash.*.log

# Local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Local CLI config
.terraformrc
terraform.rc
